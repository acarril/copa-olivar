---
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';
import Base from '../../layouts/Base.astro';
import { players, matches, categories, editions, slugify, displayName } from '../../lib/data.js';

export function getStaticPaths() {
  return Object.values(players).map((p: any) => ({
    params: { player_id: slugify(p.name, p.surname) },
    props: { player: p },
  }));
}

const { player } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const ROUND_LABELS: Record<string, string> = {
  R16: 'Octavos', QF: 'Cuartos', SF: 'Semis', '3P': '3.er Puesto', F: 'Final',
};

const catById = Object.fromEntries(categories.map((c: any) => [c.category_id, c]));
const editionById = Object.fromEntries(editions.map((e: any) => [e.edition_id, e]));
const currentYear = Math.max(...editions.map((e: any) => Number(e.year)));

function catUrl(cat: any): string {
  const year = editionById[cat.edition_id]?.year;
  return `${base}/${year}/${cat.slug}`;
}

const playerMatches = matches.filter((m: any) =>
  m.winner1_id === player.player_id || m.loser1_id === player.player_id
);

const wins = playerMatches.filter((m: any) => m.winner1_id === player.player_id);
const losses = playerMatches.filter((m: any) => m.loser1_id === player.player_id);
const winPct = playerMatches.length > 0 ? Math.round(wins.length / playerMatches.length * 100) : null;
const titles = wins.filter((m: any) => m.round === 'F');

const ROUND_RANK: Record<string, number> = { R16: 1, QF: 2, SF: 3, '3P': 3, F: 4 };
const sortedMatches = [...playerMatches].sort((a: any, b: any) => {
  const yearA = Number(editionById[catById[a.category_id]?.edition_id]?.year);
  const yearB = Number(editionById[catById[b.category_id]?.edition_id]?.year);
  if (yearB !== yearA) return yearB - yearA;
  return (ROUND_RANK[b.round] ?? 0) - (ROUND_RANK[a.round] ?? 0);
});

const playedCategories = [...new Set(playerMatches.map((m: any) => m.category_id))]
  .map((id: any) => catById[id])
  .filter(Boolean);

function reverseScore(score: string): string {
  if (!score) return score;
  // Super tiebreak format: [10-7] → [7-10]
  const st = score.match(/^\[(\d+)-(\d+)\]$/);
  if (st) return `[${st[2]}-${st[1]}]`;
  // Standard format: 6-3 or 6-5(4) → 3-6 or 5-6(4)
  const s = score.match(/^(\d+)-(\d+)(\(\d+\))?$/);
  if (s) return `${s[2]}-${s[1]}${s[3] ?? ''}`;
  return score;
}

// Avatar color cycles through design system palette based on player number
const AVATAR_COLORS = ['var(--c-blue)', 'var(--c-green)', 'var(--c-pink)', 'var(--c-yellow)'];
const avatarColor = AVATAR_COLORS[(parseInt(player.player_id.slice(1)) - 1) % 4];

const initials = `${player.name} ${player.surname}`.split(' ').filter(Boolean).slice(0, 2).map((w: string) => w[0]).join('');

const photoExts = ['jpg', 'jpeg', 'png', 'webp'];
const foundExt = photoExts.find(ext =>
  existsSync(resolve(process.cwd(), `public/images/players/${player.player_id}.${ext}`))
);
const photoSrc = foundExt ? `${base}/images/players/${player.player_id}.${foundExt}` : null;
---

<Base title={displayName(player)}>
  <div class="breadcrumb">
    <a href={`${base}/`}>Copa Olivar</a>
    <span>/</span>
    <a href={`${base}/jugadores`}>Jugadores</a>
    <span>/</span>
  </div>

  <div class="profile-card">
    {photoSrc
      ? <img class="avatar photo clickable" src={photoSrc} alt={`${player.name} ${player.surname}`} onclick="document.getElementById('photo-modal').showModal()" />
      : <div class="avatar" style={`background: ${avatarColor}`}>{initials}</div>
    }
    <div class="profile-info">
      <h1>{player.name} {player.surname}</h1>
      {titles.length > 0 && (
        <div class="titles">
          {titles.map((m: any) => {
            const cat = catById[m.category_id];
            return (
              <a href={cat ? catUrl(cat) : undefined} class="title-badge">
                &#10032; {cat?.label ?? 'Campeón'} {editionById[cat?.edition_id]?.year}
              </a>
            );
          })}
        </div>
      )}
    </div>
  </div>

  <div class="stats-row">
    <div class="stat-card">
      <span class="stat-value">{wins.length}</span>
      <span class="stat-label">Victorias</span>
    </div>
    <div class="stat-card">
      <span class="stat-value">{losses.length}</span>
      <span class="stat-label">Derrotas</span>
    </div>
    <div class="stat-card">
      <span class="stat-value">{winPct !== null ? `${winPct}%` : '—'}</span>
      <span class="stat-label">% victorias</span>
    </div>
    <div class="stat-card">
      <span class="stat-value">{titles.length}</span>
      <span class="stat-label">{titles.length === 1 ? 'Título' : 'Títulos'}</span>
    </div>
  </div>

  {playedCategories.length > 0 && (
    <div class="section-card">
      <h2>Categorías</h2>
      <div class="cat-list">
        {playedCategories.map((cat: any) => (
          <a href={catUrl(cat)} class="cat-pill">
            {cat.label} {editionById[cat.edition_id]?.year}
          </a>
        ))}
      </div>
    </div>
  )}

  {sortedMatches.length > 0 ? (
    <div class="section-card">
      <h2>Historial de partidos</h2>
      <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th></th>
            <th>Ronda</th>
            <th>Año</th>
            <th class="hide-mobile">Categoría</th>
            <th>Rival</th>
            <th>Resultado</th>
          </tr>
        </thead>
        <tbody>
          {sortedMatches.map((m: any) => {
            const isWin = m.winner1_id === player.player_id;
            const opponentId = isWin ? m.loser1_id : m.winner1_id;
            const opponent = (players as any)[opponentId];
            const cat = catById[m.category_id];
            const year = Number(editionById[cat?.edition_id]?.year);
            const isCurrent = year === currentYear;
            const isUnconfirmed = m.notes?.includes('unconfirmed');
            const isMissingScore = opponent && !m.score;
            const suggestData = opponent ? JSON.stringify({
              winner: isWin ? displayName(player) : displayName(opponent),
              loser: isWin ? displayName(opponent) : displayName(player),
              round: m.round,
              context: cat ? `${cat.label} ${year}` : '',
            }) : null;
            return (
              <tr class={isCurrent ? 'row-current' : 'row-historical'}>
                <td>
                  <span class={isWin ? 'badge win' : 'badge loss'}>
                    {isWin ? 'V' : 'D'}
                  </span>
                </td>
                <td class="round-cell">{ROUND_LABELS[m.round] ?? m.round}</td>
                <td class="year-cell">{year || '—'}</td>
                <td class="hide-mobile">
                  {cat
                    ? <a href={catUrl(cat)} class="cat-link">{cat.label}</a>
                    : '—'
                  }
                </td>
                <td>
                  {opponent
                    ? <a href={`${base}/jugador/${slugify(opponent.name, opponent.surname)}`} class="player-link">{displayName(opponent)}</a>
                    : '—'
                  }
                </td>
                <td class="score-cell">
                  <div class="score-inner">
                    <span>{m.score ? (isWin ? m.score : reverseScore(m.score)) : '—'}</span>
                    {isUnconfirmed && suggestData && (
                      <button class="suggest-btn" onclick={`openSuggestModal(${suggestData})`} title="Resultado no confirmado — haz clic para sugerir">?</button>
                    )}
                    {isMissingScore && !isUnconfirmed && suggestData && (
                      <button class="suggest-btn suggest-btn-missing" onclick={`openSuggestModal(${suggestData})`} title="¿Recuerdas este resultado?">?</button>
                    )}
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
      </div>
    </div>
  ) : (
    <div class="section-card empty">
      <p>Sin partidos registrados.</p>
    </div>
  )}

  {photoSrc && (
    <dialog id="photo-modal">
      <div class="photo-modal-header">
        <span>{player.name} {player.surname}</span>
        <button onclick="document.getElementById('photo-modal').close()" aria-label="Cerrar">✕</button>
      </div>
      <div class="photo-modal-body">
        <img src={photoSrc} alt={`${player.name} ${player.surname}`} />
      </div>
    </dialog>
  )}
</Base>

<style>
  .breadcrumb {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--c-text);
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .breadcrumb a {
    text-decoration: none;
    padding-bottom: 2px;
    background-image: linear-gradient(currentColor, currentColor);
    background-repeat: no-repeat;
    background-size: 100% 1.5px;
    background-position: left bottom;
    transition: background-size 0.4s ease;
  }
  .breadcrumb a:hover {
    background-image: linear-gradient(var(--c-yellow), var(--c-yellow));
    background-size: 100% 5px;
  }

  .profile-card {
    background: #fff;
    border: var(--border);
    box-shadow: var(--shadow-card);
    padding: 1.5rem 1.75rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }

  .avatar {
    width: 72px;
    height: 72px;
    border: var(--border);
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--c-black);
    letter-spacing: -0.02em;
  }

  .avatar.photo {
    object-fit: cover;
  }

  .avatar.clickable {
    cursor: zoom-in;
    transition: box-shadow 0.1s, transform 0.1s;
  }
  .avatar.clickable:hover {
    box-shadow: var(--shadow-card);
    transform: translate(-2px, -2px);
  }

  #photo-modal {
    border: var(--border);
    box-shadow: var(--shadow-hover);
    padding: 0;
    max-width: min(600px, calc(100vw - 2rem));
    width: 100%;
    background: #fff;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    margin: 0;
  }
  #photo-modal::backdrop { background: rgba(0,0,0,0.75); }

  .photo-modal-header {
    background: var(--c-yellow);
    border-bottom: var(--border);
    padding: 0.75rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--c-black);
  }
  .photo-modal-header button {
    background: none;
    border: none;
    font-size: 1rem;
    cursor: pointer;
    color: var(--c-black);
    padding: 0;
    line-height: 1;
    font-family: inherit;
  }

  .photo-modal-body img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 80vh;
    object-fit: contain;
  }

  .profile-info { display: flex; flex-direction: column; gap: 0.3rem; }

  h1 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--c-black);
    line-height: 1.1;
  }

  .titles { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.2rem; }

  .title-badge {
    font-size: 0.78rem;
    font-weight: 700;
    background: var(--c-blue);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    padding: 0.2rem 0.6rem;
    color: var(--c-black);
    text-decoration: none;
    transition: box-shadow 0.1s, transform 0.1s;
  }
  .title-badge:hover {
    box-shadow: var(--shadow-card);
    transform: translate(-2px, -2px);
  }

  .stats-row {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .stat-card {
    flex: 1;
    background: #fff;
    border: var(--border);
    box-shadow: var(--shadow-sm);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-value {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--c-black);
    line-height: 1;
  }
  .stat-sub {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--c-text);
    margin-left: 1px;
  }

  .stat-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-text);
  }

  .section-card {
    background: #fff;
    border: var(--border);
    box-shadow: var(--shadow-card);
    padding: 0.8rem 1.75rem;
    margin-bottom: 1rem;
  }

  h2 {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-text);
    margin-bottom: 1rem;
  }

  .cat-list { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .cat-pill {
    font-size: 0.82rem;
    font-weight: 600;
    background: var(--c-cream);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    padding: 0.25rem 0.65rem;
    color: var(--c-black);
    transition: box-shadow 0.1s, transform 0.1s;
  }
  .cat-pill:hover {
    box-shadow: var(--shadow-card);
    transform: translate(-2px, -2px);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  th {
    text-align: left;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-text);
    padding: 0 0.8rem 0.6rem 0;
    border-bottom: var(--border);
  }

  td {
    padding: 0.6rem 0.8rem 0.6rem 0;
    border-bottom: 1px solid #e5e7eb;
    vertical-align: middle;
  }

  tr:last-child td { border-bottom: none; }

  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.15rem 0.4rem;
    border: var(--border);
  }
  .badge.win { background: var(--c-green); color: var(--c-black); }
  .badge.loss { background: var(--c-bg); color: var(--c-text); }

  .table-wrap { overflow-x: auto; }

  tr.row-current td { background: var(--c-bg); }
  tr.row-historical td { background: #fff; }

  .round-cell { color: var(--c-text); font-size: 0.85rem; }

  .year-cell {
    font-family: "SF Mono", "Fira Code", ui-monospace, monospace;
    font-size: 0.82rem;
    color: var(--c-text);
  }

  .cat-link {
    font-size: 0.85rem;
    color: var(--c-text);
    text-decoration: none;
    padding-bottom: 2px;
    background-image: linear-gradient(currentColor, currentColor);
    background-repeat: no-repeat;
    background-size: 100% 1.5px;
    background-position: left bottom;
    transition: background-size 0.4s ease;
  }
  .cat-link:hover {
    background-image: linear-gradient(var(--c-yellow), var(--c-yellow));
    background-size: 100% 5px;
  }

  .player-link {
    font-weight: 600;
    color: var(--c-black);
    text-decoration: none;
    padding-bottom: 2px;
    background-image: linear-gradient(currentColor, currentColor);
    background-repeat: no-repeat;
    background-size: 100% 1.5px;
    background-position: left bottom;
    transition: background-size 0.4s ease;
  }
  .player-link:hover {
    background-image: linear-gradient(var(--c-yellow), var(--c-yellow));
    background-size: 100% 5px;
  }

  .score-cell {
    font-family: "SF Mono", "Fira Code", ui-monospace, monospace;
    font-size: 0.82rem;
    color: var(--c-text);
    width: 1%;
    white-space: nowrap;
  }

  .score-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .suggest-btn {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    background: var(--c-yellow);
    color: var(--c-black);
    border: 1px solid var(--c-black);
    padding: 1px 4px;
    margin-left: auto;
    vertical-align: middle;
    font-family: inherit;
    cursor: pointer;
    transition: box-shadow 0.1s, transform 0.1s;
  }
  .suggest-btn:hover {
    box-shadow: 2px 2px 0 var(--c-black);
    transform: translate(-1px, -1px);
  }

  .empty p {
    color: var(--c-text);
    font-size: 0.9rem;
  }

  @media (max-width: 600px) {
    .hide-mobile { display: none; }
    .stats-row { flex-wrap: wrap; }
    .stat-card { flex: 1 1 calc(50% - 0.375rem); }
  }
</style>

<script is:inline>
  var photoModal = document.getElementById('photo-modal');
  if (photoModal) {
    photoModal.addEventListener('click', function(e) {
      if (e.target === this) this.close();
    });
  }
</script>

---
import Base from '../../layouts/Base.astro';
import { editions, categories, matches, players, slugify, displayName } from '../../lib/data.js';

export function getStaticPaths() {
  return editions.map(e => ({ params: { year: e.year }, props: { edition: e } }));
}

const { edition } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const editionCats = categories.filter(c => c.edition_id === edition.edition_id);
const rows = editionCats.map(cat => {
  const final = matches.find(m => m.category_id === cat.category_id && m.round === 'F');
  return {
    cat,
    champion: final ? players[final.winner1_id] : null,
    runnerUp: final ? players[final.loser1_id] : null,
    score: final?.score ?? null,
  };
});

// ── Weekend weather ──────────────────────────────────────────────────────────
const LAT = -34.210109;
const LON = -70.835653;

function wmoCondition(code) {
  const c = Number(code);
  if (c === 0)  return 'Despejado';
  if (c === 1)  return 'Mayormente despejado';
  if (c === 2)  return 'Parcialmente nublado';
  if (c === 3)  return 'Nublado';
  if (c <= 48)  return 'Niebla';
  if (c <= 55)  return 'Llovizna';
  if (c <= 65)  return 'Lluvia';
  if (c <= 77)  return 'Nieve';
  if (c <= 82)  return 'Chubascos';
  return 'Tormenta';
}

function windDir(deg) {
  const dirs = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSO','SO','OSO','O','ONO','NO','NNO'];
  return dirs[Math.round(Number(deg) / 22.5) % 16];
}

function fmtRad(mjm2) {
  return (mjm2 / 3.6).toFixed(1); // MJ/m2 to kWh/m2
}

function toDMS(lat, lon) {
  const fmt = (val, pos, neg) => {
    const abs = Math.abs(val);
    const deg = Math.floor(abs);
    const minFull = (abs - deg) * 60;
    const min = Math.floor(minFull);
    const sec = ((minFull - min) * 60).toFixed(1).padStart(4, '0');
    return `${deg}°${String(min).padStart(2,'0')}'${sec}"${val >= 0 ? pos : neg}`;
  };
  return `${fmt(lat,'N','S')} ${fmt(lon,'E','W')}`;
}

function fmtTime(iso) {
  return iso ? iso.slice(11, 16) : '—';
}

function toISO(date) {
  return `${date.getFullYear()}-${String(date.getMonth()+1).padStart(2,'0')}-${String(date.getDate()).padStart(2,'0')}`;
}

function formatDate(dateStr) {
  const [y, m, d] = dateStr.split('-').map(Number);
  return new Date(y, m-1, d).toLocaleDateString('es-CL', { day: 'numeric', month: 'long' });
}

let weekend = null;
if (edition.date_start) {
  const [y, m, d] = edition.date_start.split('-').map(Number);
  const sat = new Date(y, m-1, d);
  const sun = new Date(y, m-1, d+1);
  const satStr = toISO(sat);
  const sunStr = toISO(sun);

  try {
    const fields = [
      'temperature_2m_max', 'temperature_2m_min',
      'precipitation_sum',
      'windspeed_10m_max', 'winddirection_10m_dominant',
      'weathercode',
      'sunrise', 'sunset',
      'shortwave_radiation_sum',
    ].join(',');
    const url = `https://archive-api.open-meteo.com/v1/archive?latitude=${LAT}&longitude=${LON}&start_date=${satStr}&end_date=${sunStr}&daily=${fields}&timezone=America%2FSantiago`;
    const res = await fetch(url);
    const data = await res.json();
    if (data.daily) {
      const dd = data.daily;
      weekend = [0, 1].map(i => ({
        date:      dd.time[i],
        condition: wmoCondition(dd.weathercode[i]),
        wmoCode:   Number(dd.weathercode[i]),
        maxTemp:   Math.round(dd.temperature_2m_max[i]),
        minTemp:   Math.round(dd.temperature_2m_min[i]),
        precip:    dd.precipitation_sum[i].toFixed(1),
        wind:      Math.round(dd.windspeed_10m_max[i]),
        windDir:   windDir(dd.winddirection_10m_dominant[i]),
        radiation: fmtRad(dd.shortwave_radiation_sum[i]),
        sunrise:   fmtTime(dd.sunrise[i]),
        sunset:    fmtTime(dd.sunset[i]),
      }));
    }
  } catch (e) {
    // weather unavailable — block won't render
  }
}

const DAY_NAMES = ['Sábado', 'Domingo'];
const DAY_CLASSES = ['day-sat', 'day-sun'];
---

<Base title={`${edition.year} — ${edition.edition_number}° edición`}>
<div class="page">
  <div class="breadcrumb">
    <a href={`${base}/`}>Abierto Olivar</a>
    <span>/</span>
  </div>

  <section class="hero">
    <div class="hero-text">
      <h1>{edition.year}</h1>
      <p>{edition.edition_number}° edición</p>
    </div>
    <img class="hero-logo" src={`${base}/images/logos/logo_abierto_olivar.png`} alt="Abierto Olivar" />
  </section>

  <section class="card">
    <h2>Campeones</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Categoría</th>
            <th>Campeón/a/es</th>
            <th>Final</th>
            <th class="hide-mobile">Finalista</th>
          </tr>
        </thead>
        <tbody>
          {rows.map(({ cat, champion, runnerUp, score }) => (
            <tr>
              <td class="cat-label"><a class="cat-badge" href={`${base}/${edition.year}/${cat.slug}`}>{cat.label}</a></td>
              <td class="champion">
                {champion
                  ? <a class="text-link" href={`${base}/jugador/${slugify(champion.name, champion.surname)}`}>{displayName(champion)}</a>
                  : '—'}
              </td>
              <td class="score">{score ?? '—'}</td>
              <td class="runner-up hide-mobile">
                {runnerUp
                  ? <a class="text-link" href={`${base}/jugador/${slugify(runnerUp.name, runnerUp.surname)}`}>{displayName(runnerUp)}</a>
                  : '—'}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  {false && weekend && (
    <div class="wx-section">
      <p class="wx-label">Clima &middot; {toDMS(LAT, LON)}</p>
      <div class="weekend-grid">
        {weekend.map((day, i) => (
          <div class={`day-card ${DAY_CLASSES[i]}`}>
            <div class="day-header">
              <span class="day-name">{DAY_NAMES[i]}</span>
              <span class="day-date">{formatDate(day.date)}</span>
            </div>
            <div class="day-body">
              <div class="condition-row">
                <span class="condition">{day.condition}</span>
                <span class="wmo-code">WMO {day.wmoCode}</span>
              </div>
              <div class="stats">
                <dl class="stats-col">
                  <div class="stat">
                    <dt>Temperatura</dt>
                    <dd><span class="val-hi">{day.maxTemp}°C</span><span class="val-sep"> / </span><span class="val-lo">{day.minTemp}°C</span></dd>
                  </div>
                  <div class="stat">
                    <dt>Precipitación</dt>
                    <dd><span class="val">{day.precip} mm</span></dd>
                  </div>
                  <div class="stat">
                    <dt>Amanecer</dt>
                    <dd><span class="val">{day.sunrise}</span></dd>
                  </div>
                </dl>
                <dl class="stats-col">
                  <div class="stat">
                    <dt>Viento</dt>
                    <dd><span class="val">{day.wind} km/h</span> <span class="badge">{day.windDir}</span></dd>
                  </div>
                  <div class="stat">
                    <dt>Radiación solar</dt>
                    <dd><span class="val">{day.radiation} kWh/m²</span></dd>
                  </div>
                  <div class="stat">
                    <dt>Atardecer</dt>
                    <dd><span class="val">{day.sunset}</span></dd>
                  </div>
                </dl>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}
</div>
</Base>

<style>
  .page { padding-bottom: 2.5rem; }

  .breadcrumb {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--c-text);
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .breadcrumb a {
    text-decoration: none;
    padding-bottom: 2px;
    background-image: linear-gradient(currentColor, currentColor);
    background-repeat: no-repeat;
    background-size: 100% 1.5px;
    background-position: left bottom;
    transition: background-size 0.4s ease;
  }
  .breadcrumb a:hover {
    background-image: linear-gradient(var(--c-yellow), var(--c-yellow));
    background-size: 100% 5px;
  }

  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: 2.6rem;
    color: var(--c-black);
    line-height: 1.1;
  }
  .hero p {
    font-size: 1rem;
    color: var(--c-text);
    margin-top: 0.35rem;
    font-weight: 300;
  }
  .hero-logo {
    height: calc(2.6rem * 1.1 + 1rem + 0.35rem);
    width: auto;
    flex-shrink: 0;
    border: var(--border);
    border-radius: 50%;
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.1s, transform 0.1s;
    cursor: default;
  }
  .hero-logo:hover {
    box-shadow: var(--shadow-hover);
    transform: translate(-2px, -2px);
  }

  .card {
    background: #fff;
    border: var(--border);
    padding: 1.5rem 1.75rem;
    box-shadow: var(--shadow-card);
  }

  h2 {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-text);
    margin-bottom: 1rem;
  }

  .table-wrap { overflow-x: auto; }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
  }

  th {
    text-align: left;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-text);
    padding: 0 0.8rem 0.6rem 0;
    border-bottom: var(--border);
  }

  td {
    padding: 0.65rem 0.8rem 0.65rem 0;
    border-bottom: 1px solid #e5e7eb;
  }

  tr:last-child td { border-bottom: none; }

  .cat-label { font-size: 0.85rem; padding-left: 3px; }
  .champion { font-weight: 700; color: var(--c-black); }
  .score {
    font-family: "SF Mono", "Fira Code", ui-monospace, monospace;
    font-size: 0.85rem;
    color: var(--c-text);
  }
  .runner-up { color: var(--c-text); font-weight: 300; }

  /* ── Weather block ───────────────────────────────────────────────────────── */
  .wx-section { margin-top: 1.5rem; }

  .wx-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-text);
    margin-bottom: 0.75rem;
  }

  .weekend-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .day-card {
    border: var(--border);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Coloured header bar */
  .day-header {
    border-bottom: var(--border);
    padding: 0.55rem 1.1rem;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .day-sat .day-header { background: var(--c-green); }
  .day-sun .day-header { background: var(--c-blue); }

  .day-name {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--c-black);
  }

  .day-date {
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--c-text);
  }

  .day-body {
    background: #fff;
    padding: 1.1rem 1.1rem 1rem;
    flex: 1;
  }

  /* Condition + WMO code row */
  .condition-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 0.85rem;
    margin-bottom: 0.85rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .condition {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--c-black);
  }

  .wmo-code {
    font-family: "SF Mono", "Fira Code", ui-monospace, monospace;
    font-size: 0.65rem;
    color: var(--c-text);
    opacity: 0.6;
  }

  /* Stats grid */
  .stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 1.5rem;
  }

  .stats-col {
    display: grid;
    grid-template-columns: max-content 1fr;
    row-gap: 0.45rem;
    column-gap: 0.75rem;
    align-content: start;
  }

  .stat { display: contents; }

  .stats dt {
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--c-text);
    align-self: center;
    white-space: nowrap;
  }

  .stats dd {
    margin: 0;
    font-family: "SF Mono", "Fira Code", ui-monospace, monospace;
    font-size: 0.8rem;
    color: var(--c-black);
    align-self: center;
  }

  .val       { font-weight: 600; }
  .val-hi    { font-weight: 700; color: var(--c-black); }
  .val-sep   { color: var(--c-text); font-weight: 300; }
  .val-lo    { font-weight: 400; color: var(--c-text); }

  .badge {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    background: var(--c-bg);
    border: 1px solid #ccc;
    padding: 0.1rem 0.35rem;
    vertical-align: middle;
    line-height: 1.6;
  }

  @media (max-width: 600px) {
    .hide-mobile { display: none; }
    .weekend-grid { grid-template-columns: 1fr; }
  }
</style>

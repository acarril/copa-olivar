---
import Base from '../../layouts/Base.astro';
import { editions, categories, matches, players, slugify, displayName } from '../../lib/data.js';

export function getStaticPaths() {
  return editions.map(e => ({ params: { year: e.year }, props: { edition: e } }));
}

const { edition } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const editionCats = categories.filter(c => c.edition_id === edition.edition_id);
const rows = editionCats.map(cat => {
  const final = matches.find(m => m.category_id === cat.category_id && m.round === 'F');
  return {
    cat,
    champion: final ? players[final.winner1_id] : null,
    runnerUp: final ? players[final.loser1_id] : null,
    score: final?.score ?? null,
  };
});
---

<Base title={`${edition.year} — ${edition.edition_number}° edición`}>
  <div class="breadcrumb">
    <a href={`${base}/`}>Copa Olivar</a>
    <span>/</span>
  </div>

  <section class="hero">
    <h1>{edition.year}</h1>
    <p>{edition.edition_number}° edición</p>
  </section>

  <section class="card">
    <h2>Campeones</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Categoría</th>
            <th>Campeón/a/es</th>
            <th>Final</th>
            <th class="hide-mobile">Finalista</th>
          </tr>
        </thead>
        <tbody>
          {rows.map(({ cat, champion, runnerUp, score }) => (
            <tr>
              <td class="cat-label"><a class="cat-link" href={`${base}/${edition.year}/${cat.slug}`}>{cat.label}</a></td>
              <td class="champion">
                {champion
                  ? <a class="text-link" href={`${base}/jugador/${slugify(champion.name, champion.surname)}`}>{displayName(champion)}</a>
                  : '—'}
              </td>
              <td class="score">{score ?? '—'}</td>
              <td class="runner-up hide-mobile">
                {runnerUp
                  ? <a class="text-link" href={`${base}/jugador/${slugify(runnerUp.name, runnerUp.surname)}`}>{displayName(runnerUp)}</a>
                  : '—'}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Base>

<style>
  .breadcrumb {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--c-text);
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .breadcrumb a {
    text-decoration: none;
    padding-bottom: 2px;
    background-image: linear-gradient(currentColor, currentColor);
    background-repeat: no-repeat;
    background-size: 100% 1.5px;
    background-position: left bottom;
    transition: background-size 0.4s ease;
  }
  .breadcrumb a:hover {
    background-image: linear-gradient(var(--c-yellow), var(--c-yellow));
    background-size: 100% 5px;
  }

  .hero {
    margin-bottom: 2rem;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: 2.6rem;
    color: var(--c-black);
    line-height: 1.1;
  }
  .hero p {
    font-size: 1rem;
    color: var(--c-text);
    margin-top: 0.35rem;
    font-weight: 300;
  }

  .card {
    background: #fff;
    border: var(--border);
    padding: 1.5rem 1.75rem;
    box-shadow: var(--shadow-card);
  }

  h2 {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-text);
    margin-bottom: 1rem;
  }

  .table-wrap { overflow-x: auto; }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
  }

  th {
    text-align: left;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-text);
    padding: 0 0.8rem 0.6rem 0;
    border-bottom: var(--border);
  }

  td {
    padding: 0.65rem 0.8rem 0.65rem 0;
    border-bottom: 1px solid #e5e7eb;
  }

  tr:last-child td { border-bottom: none; }

  .cat-label { font-size: 0.85rem; padding-left: 3px; }
  .champion { font-weight: 700; color: var(--c-black); }
  .score {
    font-family: "SF Mono", "Fira Code", ui-monospace, monospace;
    font-size: 0.85rem;
    color: var(--c-text);
  }
  .runner-up { color: var(--c-text); font-weight: 300; }

  .cat-link {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    white-space: nowrap;
    padding: 0.2rem 0.6rem;
    background: var(--c-blue);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    color: var(--c-black);
    text-decoration: none;
    transition: box-shadow 0.1s, transform 0.1s;
  }
  .cat-link:hover {
    box-shadow: var(--shadow-card);
    transform: translate(-2px, -2px);
  }

  @media (max-width: 600px) {
    .hide-mobile { display: none; }
  }
</style>

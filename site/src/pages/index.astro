---
import Base from '../layouts/Base.astro';
import { editions, categories, matches, players, slugify, displayName } from '../lib/data.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sortedEditions = [...editions].sort((a, b) => Number(b.year) - Number(a.year));
const currentYear = Math.max(...sortedEditions.map(e => Number(e.year)));

const editionData = sortedEditions.map(edition => {
  const editionCats = categories.filter(c => c.edition_id === edition.edition_id);
  const rows = editionCats.map(cat => {
    const final = matches.find(m => m.category_id === cat.category_id && m.round === 'F');
    return {
      cat,
      champion: final ? players[final.winner1_id] : null,
      runnerUp: final ? players[final.loser1_id] : null,
      score: final?.score ?? null,
    };
  });
  return { edition, rows };
});
---

<Base>
  <section class="hero">
    <div class="hero-text">
      <h1>Abierto de Tenis Olivar</h1>
      <p>Federación Rural de Tenis Olivar</p>
    </div>
    <img class="hero-logo" src={`${base}/images/logos/logo_abierto_olivar.png`} alt="Abierto de Tenis Olivar" />
  </section>

  {editionData.map(({ edition, rows }) => (
    <section class="card">
      <a href={`${base}/${edition.year}/`} class="edition-title">
        {edition.year} &mdash; {edition.edition_number}° edición
      </a>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Categoría</th>
              <th>Campeón/a</th>
              <th>Final</th>
              <th class="hide-mobile">Finalista</th>
              <th class="hide-mobile"></th>
            </tr>
          </thead>
          <tbody>
            {rows.map(({ cat, champion, runnerUp, score }) => (
              <tr>
                <td class="cat-label"><a class="text-link" href={`${base}/${edition.year}/${cat.slug}`}>{cat.label}</a></td>
                <td class="champion">
                  {champion
                    ? <a class="text-link" href={`${base}/jugador/${slugify(champion.name, champion.surname)}`}>{displayName(champion)}</a>
                    : '—'}
                </td>
                <td class="score">{score ?? '—'}</td>
                <td class="runner-up hide-mobile">
                  {runnerUp
                    ? <a class="text-link" href={`${base}/jugador/${slugify(runnerUp.name, runnerUp.surname)}`}>{displayName(runnerUp)}</a>
                    : '—'}
                </td>
                <td class="hide-mobile">
                  <a href={`${base}/${edition.year}/${cat.slug}`} class="draw-link">
                    Cuadro
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  ))}
</Base>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: 2.6rem;
    color: var(--c-black);
    line-height: 1.1;
  }
  .hero p {
    font-size: 1rem;
    color: var(--c-text);
    margin-top: 0.35rem;
    font-weight: 300;
  }
  .hero-logo {
    height: calc(2.6rem * 1.1 + 1rem + 0.35rem);
    width: auto;
    flex-shrink: 0;
  }

  .card {
    background: #fff;
    border: var(--border);
    padding: 1.5rem 1.75rem;
    box-shadow: var(--shadow-card);
    margin-bottom: 1.5rem;
  }

  .edition-title {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.6rem;
    margin-bottom: 1rem;
    background: var(--c-yellow);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    color: var(--c-black);
    text-decoration: none;
    transition: box-shadow 0.1s, transform 0.1s;
  }
  .edition-title:hover {
    box-shadow: var(--shadow-card);
    transform: translate(-2px, -2px);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
  }

  th {
    text-align: left;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-text);
    padding: 0 0.8rem 0.6rem 0;
    border-bottom: var(--border);
  }

  td {
    padding: 0.65rem 0.8rem 0.65rem 0;
    border-bottom: 1px solid #e5e7eb;
  }

  tr:last-child td { border-bottom: none; }

  .cat-label { color: var(--c-text); font-size: 0.85rem; }
  .champion { font-weight: 700; color: var(--c-black); }
  .score {
    font-family: "SF Mono", "Fira Code", ui-monospace, monospace;
    font-size: 0.85rem;
    color: var(--c-text);
  }
  .runner-up { color: var(--c-text); font-weight: 300; }

  .draw-link {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    white-space: nowrap;
    padding: 0.2rem 0.6rem;
    background: var(--c-blue);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    color: var(--c-black);
    transition: box-shadow 0.1s, transform 0.1s;
  }
  .draw-link:hover {
    box-shadow: var(--shadow-card);
    transform: translate(-2px, -2px);
  }

  .table-wrap { overflow-x: auto; }

  @media (max-width: 600px) {
    .hide-mobile { display: none; }
  }
</style>

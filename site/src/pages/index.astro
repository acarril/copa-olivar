---
import Base from '../layouts/Base.astro';
import { editions, categories, matches, players, slugify } from '../lib/data.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sortedEditions = [...editions].sort((a, b) => Number(b.year) - Number(a.year));
const currentEdition = sortedEditions[0];
const currentYear = Number(currentEdition.year);

const editionData = sortedEditions.map(edition => {
  const editionCats = categories.filter(c => c.edition_id === edition.edition_id);
  const rows = editionCats.map(cat => {
    const final = matches.find(m => m.category_id === cat.category_id && m.round === 'F');
    return {
      cat,
      champion: final ? players[final.winner1_id] : null,
      championId: final?.winner1_id ?? null,
      runnerUp: final ? players[final.loser1_id] : null,
      runnerUpId: final?.loser1_id ?? null,
      score: final?.score ?? null,
    };
  });
  return { edition, rows };
});

function displayName(p) {
  if (!p) return '—';
  return p.nickname ? `${p.nickname} ${p.name.split(' ').at(-1)}` : p.name.split(' ').slice(0, 2).join(' ');
}
---

<Base>
  <section class="hero">
    <h1>Olivar Open</h1>
    <p>{currentEdition.edition_number}.a edición &mdash; {currentEdition.year}</p>
  </section>

  {editionData.map(({ edition, rows }) => (
    <section class="card">
      <h2>Campeones {edition.year}</h2>
      <table>
        <thead>
          <tr>
            <th>Categoría</th>
            <th>Campeón/a</th>
            <th>Final</th>
            <th>Finalista</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {rows.map(({ cat, champion, championId, runnerUp, runnerUpId, score }) => (
            <tr>
              <td class="cat-label">{cat.label}</td>
              <td class="champion">
                {champion && championId
                  ? <a class="text-link" href={`${base}/jugador/${slugify(champion.name)}`}>{displayName(champion)}</a>
                  : '—'}
              </td>
              <td class="score">{score ?? '—'}</td>
              <td class="runner-up">
                {runnerUp && runnerUpId
                  ? <a class="text-link" href={`${base}/jugador/${slugify(runnerUp.name)}`}>{displayName(runnerUp)}</a>
                  : '—'}
              </td>
              <td>
                <a href={Number(edition.year) === currentYear
                    ? `${base}/categoria/${cat.slug}`
                    : `${base}/categoria/${cat.slug}/${edition.year}`} class="draw-link">
                  Ver cuadro →
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  ))}
</Base>

<style>
  .hero {
    margin-bottom: 2rem;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: 2.6rem;
    color: var(--c-black);
    line-height: 1.1;
  }
  .hero p {
    font-size: 1rem;
    color: var(--c-text);
    margin-top: 0.35rem;
    font-weight: 300;
  }

  .card {
    background: #fff;
    border: var(--border);
    padding: 1.5rem 1.75rem;
    box-shadow: var(--shadow-card);
    margin-bottom: 1.5rem;
  }

  h2 {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-text);
    margin-bottom: 1rem;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
  }

  th {
    text-align: left;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-text);
    padding: 0 0 0.6rem;
    border-bottom: var(--border);
  }

  td {
    padding: 0.65rem 0;
    border-bottom: 1px solid #e5e7eb;
  }

  tr:last-child td { border-bottom: none; }

  .cat-label { color: var(--c-text); font-size: 0.85rem; }
  .champion { font-weight: 700; color: var(--c-black); }
  .score {
    font-family: "SF Mono", "Fira Code", ui-monospace, monospace;
    font-size: 0.85rem;
    color: var(--c-text);
  }
  .runner-up { color: var(--c-text); font-weight: 300; }

  .draw-link {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    white-space: nowrap;
    padding: 0.2rem 0.6rem;
    background: var(--c-blue);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    color: var(--c-black);
    transition: box-shadow 0.1s, transform 0.1s;
  }
  .draw-link:hover {
    box-shadow: var(--shadow-card);
    transform: translate(-2px, -2px);
  }
</style>

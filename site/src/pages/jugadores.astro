---
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';
import Base from '../layouts/Base.astro';
import { players, matches, displayName, slugify } from '../lib/data.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const PHOTO_EXTS = ['jpg', 'jpeg', 'png', 'webp'];
function findPhoto(player_id: string): string | null {
  const ext = PHOTO_EXTS.find(e =>
    existsSync(resolve(process.cwd(), `public/images/players/${player_id}.${e}`))
  );
  return ext ? `${base}/images/players/${player_id}.${ext}` : null;
}

const AVATAR_COLORS = ['var(--c-blue)', 'var(--c-green)', 'var(--c-pink)', 'var(--c-yellow)'];

// Sort by surname
const sortedPlayers = (Object.values(players) as any[]).sort((a, b) =>
  a.surname.localeCompare(b.surname, 'es')
);

// Precompute win/title counts
const winsByPlayer: Record<string, number> = {};
const titlesByPlayer: Record<string, number> = {};
for (const p of Object.values(players) as any[]) {
  const pid = p.player_id;
  const wins = (matches as any[]).filter(m => m.winner1_id === pid || m.winner2_id === pid);
  winsByPlayer[pid] = wins.length;
  titlesByPlayer[pid] = wins.filter(m => m.round === 'F').length;
}
---

<Base title="Jugadores">
  <section class="hero">
    <div class="hero-text">
      <h1>Jugadores</h1>
      <p>{sortedPlayers.length} participantes · Copa Olivar</p>
    </div>
    <img class="hero-logo" src={`${base}/images/logos/logo_abierto_olivar.png`} alt="Copa Olivar" />
  </section>

  <div class="search-wrap">
    <input
      type="search"
      id="player-search"
      placeholder="Buscar jugador..."
      autocomplete="off"
      spellcheck="false"
    />
  </div>

  <div class="players-grid" id="players-grid">
    {sortedPlayers.map((p: any) => {
      const idx = parseInt(p.player_id.slice(1)) - 1;
      const color = AVATAR_COLORS[idx % 4];
      const initials = `${p.name} ${p.surname}`.split(' ').filter(Boolean).slice(0, 2).map((w: string) => w[0]).join('');
      const photoSrc = findPhoto(p.player_id);
      const slug = slugify(p.name, p.surname);
      const wins = winsByPlayer[p.player_id] ?? 0;
      const titles = titlesByPlayer[p.player_id] ?? 0;
      const searchKey = `${p.name} ${p.surname} ${p.nickname ?? ''}`.toLowerCase();
      return (
        <a
          href={`${base}/jugador/${slug}`}
          class="player-card"
          data-search={searchKey}
        >
          {photoSrc
            ? <img class="card-avatar photo" src={photoSrc} alt={`${p.name} ${p.surname}`} />
            : <div class="card-avatar" style={`background: ${color}`}>{initials}</div>
          }
          <div class="card-info">
            <span class="card-surname">{p.surname}</span>
            <span class="card-name">{p.name}</span>
          </div>
          <div class="card-stats">
            {titles > 0 && (
              <span class="stat-pill gold" title="Títulos">&#10032; {titles}</span>
            )}
            <span class="stat-pill" title="Victorias">{wins}V</span>
          </div>
        </a>
      );
    })}
  </div>

  <p class="no-results" id="no-results" hidden>No se encontraron jugadores.</p>
</Base>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: 2.6rem;
    color: var(--c-black);
    line-height: 1.1;
  }

  .hero p {
    font-size: 1rem;
    color: var(--c-text);
    margin-top: 0.35rem;
    font-weight: 300;
  }

  .hero-logo {
    height: calc(2.6rem * 1.1 + 1rem + 0.35rem);
    width: auto;
    flex-shrink: 0;
    border: var(--border);
    border-radius: 50%;
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.1s, transform 0.1s;
    cursor: default;
  }
  .hero-logo:hover {
    box-shadow: var(--shadow-hover);
    transform: translate(-2px, -2px);
  }

  .search-wrap {
    margin-bottom: 1.75rem;
  }

  #player-search {
    width: 100%;
    padding: 0.65rem 1rem;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 600;
    border: var(--border);
    box-shadow: var(--shadow-card);
    background: #fff;
    color: var(--c-black);
    outline: none;
    transition: box-shadow 0.1s;
  }

  #player-search:focus {
    box-shadow: var(--shadow-hover);
  }

  #player-search::placeholder {
    color: #aaa;
    font-weight: 400;
  }

  .players-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    padding: 0 3px 3px 0;
  }

  @media (max-width: 640px) {
    .players-grid { grid-template-columns: 1fr; }
  }

  .player-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    background: #fff;
    border: var(--border);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    transition: box-shadow 0.1s, transform 0.1s;
    min-width: 0;
  }

  .player-card:hover {
    box-shadow: var(--shadow-card);
    transform: translate(-2px, -2px);
  }

  .card-avatar {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--c-black);
  }

  .card-avatar.photo {
    object-fit: cover;
  }

  .card-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .card-surname {
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--c-black);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-name {
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--c-text);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-stats {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    flex-shrink: 0;
    width: 2.5rem;
  }

  .stat-pill {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    border: 1.5px solid var(--c-black);
    background: var(--c-bg);
    color: var(--c-black);
    white-space: nowrap;
  }

  .stat-pill.gold {
    background: var(--c-yellow);
  }

  .no-results {
    text-align: center;
    padding: 3rem 0;
    color: var(--c-text);
    font-size: 0.9rem;
  }
</style>

<script is:inline>
  var input = document.getElementById('player-search');
  var grid = document.getElementById('players-grid');
  var noResults = document.getElementById('no-results');

  input.addEventListener('input', function () {
    var q = this.value.toLowerCase().trim();
    var cards = Array.from(grid.querySelectorAll('.player-card'));

    if (!q) {
      cards.forEach(function (card) { card.style.display = ''; grid.appendChild(card); });
      noResults.hidden = true;
      return;
    }

    var starts = [], contains = [], hidden = [];
    cards.forEach(function (card) {
      var search = card.dataset.search;
      if (!search.includes(q)) {
        hidden.push(card);
      } else if (search.split(' ').some(function (w) { return w.startsWith(q); })) {
        starts.push(card);
      } else {
        contains.push(card);
      }
    });

    starts.concat(contains).forEach(function (card) { card.style.display = ''; grid.appendChild(card); });
    hidden.forEach(function (card) { card.style.display = 'none'; });
    noResults.hidden = starts.length + contains.length > 0;
  });
</script>

---
import Base from '../../layouts/Base.astro';
import Bracket from '../../components/Bracket.astro';
import { tournaments, matches, players, editions, slugify, displayName } from '../../lib/data.js';

export function getStaticPaths() {
  return [];
}

const { cat } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const edition = editions.find(e => e.edition_id === cat.edition_id);
const catMatches = matches.filter(m => m.tournament_id === cat.tournament_id);

const final = catMatches.find(m => m.round === 'F');
const champion = final ? players[final.winner1_id] : null;
const championName = champion ? displayName(champion) : null;
const championUrl = champion ? `${base}/jugador/${slugify(champion.name, champion.surname)}` : null;
---

<Base title={cat.label}>
  <div class="header">
    <div class="breadcrumb">
      <a href={`${base}/`}>Abierto Olivar {edition?.year}</a>
      <span>/</span>
    </div>
    <h1>{cat.label}</h1>
    {championName && championUrl && (
      <a href={championUrl} class="champion-badge">
        <span class="trophy">&#10032;</span> {championName}
      </a>
    )}
  </div>

  <div class="bracket-card">
    <Bracket matches={catMatches} players={players} />
  </div>
</Base>

<style>
  .header {
    margin-bottom: 1.5rem;
  }

  .breadcrumb {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--c-text);
    margin-bottom: 0.5rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .breadcrumb a {
    text-decoration: none;
    padding-bottom: 2px;
    background-image: linear-gradient(currentColor, currentColor);
    background-repeat: no-repeat;
    background-size: 100% 1.5px;
    background-position: left bottom;
    transition: background-size 0.4s ease;
  }
  .breadcrumb a:hover {
    background-image: linear-gradient(var(--c-yellow), var(--c-yellow));
    background-size: 100% 5px;
  }

  h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--c-black);
  }

  .champion-badge {
    margin-top: 0.6rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--c-blue);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    color: var(--c-black);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.3rem 0.75rem;
    text-decoration: none;
    transition: box-shadow 0.1s, transform 0.1s;
  }
  .champion-badge:hover {
    box-shadow: var(--shadow-card);
    transform: translate(-2px, -2px);
  }

  .trophy { font-size: 0.85rem; }

  .bracket-card {
    background: #fff;
    border: var(--border);
    padding: 1.5rem;
    box-shadow: var(--shadow-card);
  }
</style>

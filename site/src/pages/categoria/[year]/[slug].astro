---
import Base from '../../../layouts/Base.astro';
import Bracket from '../../../components/Bracket.astro';
import { categories, matches, players, editions } from '../../../lib/data.js';

export function getStaticPaths() {
  return categories.map(cat => {
    const edition = editions.find(e => e.edition_id === cat.edition_id);
    return {
      params: { year: edition.year, slug: cat.slug },
      props: { cat },
    };
  });
}

const { cat } = Astro.props;
const edition = editions.find(e => e.edition_id === cat.edition_id);
const catMatches = matches.filter(m => m.category_id === cat.category_id);

const final = catMatches.find(m => m.round === 'F');
const champion = final ? players[final.winner1_id] : null;
const championName = champion
  ? (champion.nickname ? `${champion.nickname} ${champion.name.split(' ').at(-1)}` : champion.name.split(' ').slice(0,2).join(' '))
  : null;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title={cat.label}>
  <div class="header">
    <div class="breadcrumb">
      <a href={`${base}/`}>Olivar Open {edition?.year}</a>
      <span>/</span>
    </div>
    <h1>{cat.label}</h1>
    {championName && (
      <div class="champion-badge">
        <span class="trophy">&#9733;</span> {championName}
      </div>
    )}
  </div>

  <div class="bracket-card">
    <Bracket matches={catMatches} players={players} />
  </div>
</Base>

<style>
  .header {
    margin-bottom: 1.5rem;
  }

  .breadcrumb {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--c-text);
    margin-bottom: 0.5rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .breadcrumb a {
    text-decoration: none;
    padding-bottom: 2px;
    background-image: linear-gradient(currentColor, currentColor);
    background-repeat: no-repeat;
    background-size: 100% 1.5px;
    background-position: left bottom;
    transition: background-size 0.4s ease;
  }
  .breadcrumb a:hover {
    background-image: linear-gradient(var(--c-yellow), var(--c-yellow));
    background-size: 100% 5px;
  }

  h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--c-black);
  }

  .champion-badge {
    margin-top: 0.6rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--c-yellow);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    color: var(--c-black);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.3rem 0.75rem;
  }

  .trophy { font-size: 0.85rem; }

  .bracket-card {
    background: #fff;
    border: var(--border);
    padding: 1.5rem;
    box-shadow: var(--shadow-card);
  }
</style>

---
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title ? `${title} — Olivar Open` : 'Olivar Open'}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #f7f5f0;
      color: #1a1a1a;
      min-height: 100vh;
    }
    a { color: inherit; text-decoration: none; }
    header {
      background: #1a3a2a;
      color: #fff;
      padding: 0 2rem;
      height: 56px;
      display: flex;
      align-items: center;
      gap: 2rem;
    }
    header .wordmark {
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: #fff;
    }
    header nav {
      display: flex;
      gap: 1.5rem;
      font-size: 0.85rem;
      color: #a8c4b0;
    }
    header nav a:hover { color: #fff; }
    main {
      max-width: 960px;
      margin: 2.5rem auto;
      padding: 0 1.5rem;
    }
  </style>
</head>
<body>
  <header>
    <a href={base} class="wordmark">OLIVAR OPEN</a>
    <nav>
      <a href={base}>Inicio</a>
    </nav>
  </header>
  <main>
    <slot />
  </main>
</body>
</html>

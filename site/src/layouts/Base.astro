---
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
const baseClean = base.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title ? `${title} — Olivar Open` : 'Olivar Open'}</title>
  <link rel="icon" type="image/svg+xml" href={`${baseClean}/favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Alexandria:wght@300;400;600;700;800&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --c-blue:    #96C7F2;
      --c-green:   #ADF296;
      --c-pink:    #F396E5;
      --c-yellow:  #F2CF96;
      --c-bg:      #F2F2F2;
      --c-text:    #4E6273;
      --c-black:   #000;
      --shadow-sm:    2px 2px 0 var(--c-black);
      --shadow-card:  4px 4px 0 var(--c-black);
      --shadow-hover: 8px 8px 0 var(--c-black);
      --border:    2px solid var(--c-black);
      --font-body: 'Alexandria', sans-serif;
      --font-display: 'Alexandria', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-body);
      background: var(--c-bg);
      color: var(--c-text);
      min-height: 100vh;
    }

    a { color: inherit; text-decoration: none; }

    /* Text links: background-simulated underline (animatable cross-browser) */
    a.text-link {
      text-decoration: none;
      padding-bottom: 2px;
      background-image: linear-gradient(currentColor, currentColor);
      background-repeat: no-repeat;
      background-size: 100% 1.5px;
      background-position: left bottom;
      transition: background-size 0.4s ease;
    }
    a.text-link:hover {
      background-image: linear-gradient(var(--c-yellow), var(--c-yellow));
      background-size: 100% 5px;
    }

    header {
      background: var(--c-bg);
      border-bottom: var(--border);
      padding: 0 2rem;
      height: 60px;
      display: flex;
      align-items: center;
      gap: 2rem;
    }

    header .wordmark {
      font-family: var(--font-display);
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--c-black);
      letter-spacing: 0.02em;
      text-transform: uppercase;
    }

    header nav {
      display: flex;
      gap: 1.5rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--c-text);
    }

    header nav a {
      padding: 0.25rem 0.6rem;
      border: var(--border);
      background: var(--c-bg);
      box-shadow: var(--shadow-sm);
      transition: box-shadow 0.1s, transform 0.1s;
    }

    header nav a:hover {
      box-shadow: var(--shadow-card);
      transform: translate(-2px, -2px);
    }

    main {
      max-width: 960px;
      margin: 2.5rem auto;
      padding: 0 1.5rem;
    }
  </style>
</head>
<body>
  <header>
    <a href={base} class="wordmark">Olivar Open</a>
    <nav>
      <a href={base}>Inicio</a>
    </nav>
  </header>
  <main>
    <slot />
  </main>
</body>
</html>

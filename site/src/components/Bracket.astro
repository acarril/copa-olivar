---
import { slugify } from '../lib/data.js';
const { matches, players, context = '' } = Astro.props;

const PREV_ROUND: Record<string, string> = { F: 'SF', SF: 'QF', QF: 'R16' };
const ROUND_ORDER = ['R16', 'QF', 'SF', '3P', 'F'];
const ROUND_LABELS: Record<string, string> = {
  R16: 'Octavos', QF: 'Cuartos', SF: 'Semis', '3P': '3.er Puesto', F: 'Final',
};

const BASE_H = 54;   // px per player slot
const LABEL_H = 28;  // px for round-label header
const CONN_W = 20;   // px width of connector SVG column
const COL_GAP = 12;  // gap between round columns and connector SVG (replaces match margin)

// --- Tree types ---
interface MatchRow { [k: string]: string }
interface Node { match: MatchRow; upper: Node | null; lower: Node | null }

// Build bracket tree upward from the final.
function buildTree(): Node | null {
  const final = matches.find((m: MatchRow) => m.round === 'F');
  if (!final) return null;

  function node(m: MatchRow): Node {
    const prev = PREV_ROUND[m.round];
    const upper = prev ? matches.find((x: MatchRow) => x.round === prev && x.winner1_id === m.winner1_id) ?? null : null;
    const lower = prev ? matches.find((x: MatchRow) => x.round === prev && x.winner1_id === m.loser1_id) ?? null : null;
    return { match: m, upper: upper ? node(upper) : null, lower: lower ? node(lower) : null };
  }

  return node(final);
}

function slotCount(n: Node | null): number {
  if (!n) return 1;
  return (n.upper ? slotCount(n.upper) : 1) + (n.lower ? slotCount(n.lower) : 1);
}

interface RoundItem {
  match: MatchRow;
  slots: number;
  upperSlots: number | null;
  lowerSlots: number | null;
  topOffset: number;
}

// Post-order traversal: children before parent, upper before lower.
// `offset` tracks the absolute slot position from the top of the bracket,
// so that columns with bye-receiving matches stay vertically aligned.
function flattenTree(tree: Node): Record<string, RoundItem[]> {
  const rounds: Record<string, RoundItem[]> = {};

  function traverse(n: Node, offset: number) {
    const upperS = n.upper ? slotCount(n.upper) : 1;
    const lowerS = n.lower ? slotCount(n.lower) : 1;
    if (n.upper) traverse(n.upper, offset);
    if (n.lower) traverse(n.lower, offset + upperS);
    const r = n.match.round;
    if (!rounds[r]) rounds[r] = [];
    rounds[r].push({
      match: n.match,
      slots: upperS + lowerS,
      upperSlots: n.upper ? upperS : null,
      lowerSlots: n.lower ? lowerS : null,
      topOffset: offset,
    });
  }

  traverse(tree, 0);
  return rounds;
}

const tree = buildTree();
const totalSlots = tree ? slotCount(tree) : 2;
const bracketH = totalSlots * BASE_H;
const roundData = tree ? flattenTree(tree) : {};

const rounds = ROUND_ORDER
  .filter(r => (roundData[r]?.length ?? 0) > 0)
  .map(r => {
    const items = roundData[r];
    const withGaps = items.map((item, i) => {
      const prevEnd = i === 0 ? 0 : items[i - 1].topOffset + items[i - 1].slots;
      return { ...item, topGap: item.topOffset - prevEnd };
    });
    return { key: r, label: ROUND_LABELS[r], items: withGaps };
  });

// Build elbow connector data for the SVG column that sits between two rounds.
// Uses the *next* round's items, which know their children's slot counts.
interface Connector {
  upperCY: number;
  lowerCY: number;
  midY: number;
}

function buildConnectors(nextItems: RoundItem[]): Connector[] {
  const result: Connector[] = [];
  for (const item of nextItems) {
    const { upperSlots, lowerSlots, slots, topOffset } = item;
    if (upperSlots !== null && lowerSlots !== null) {
      const topY = topOffset * BASE_H;
      const upperCY = topY + (upperSlots / 2) * BASE_H;
      const lowerCY = topY + (upperSlots + lowerSlots / 2) * BASE_H;
      const midY  = topY + (slots / 2) * BASE_H;
      result.push({ upperCY, lowerCY, midY });
    }
  }
  return result;
}

// --- Display helpers ---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function displayName(id: string): string {
  const p = (players as Record<string, Record<string, string>>)[id];
  if (!p) return '';
  return p.nickname || p.name.split(' ')[0];
}

function playerUrl(id: string): string {
  const p = (players as Record<string, Record<string, string>>)[id];
  return `${base}/jugador/${p ? slugify(p.name, p.surname) : id}`;
}

function parseScore(score: string): { w: string; l: string; tb: string | null } | null {
  if (!score) return null;
  const st = score.match(/^\[(\d+)-(\d+)\]$/);
  if (st) return { w: st[1], l: st[2], tb: null };
  const s = score.match(/^(\d+)-(\d+)(?:\((\d+)\))?$/);
  if (s) return { w: s[1], l: s[2], tb: s[3] ?? null };
  return null;
}
---

<div class="bracket-scroll">
  <div class="bracket" style={`height: ${bracketH + LABEL_H}px`}>
    {rounds.map(({ label, items }, ri) => {
      const isLast = ri === rounds.length - 1;
      const nextItems = isLast ? null : rounds[ri + 1].items;
      const connectors = nextItems ? buildConnectors(nextItems) : [];
      return (
        <>
          <div class="round">
            <div class="round-label">{label}</div>
            <div class="round-matches" style={`height: ${bracketH}px`}>
              {items.map(({ match: m, slots, topGap }) => {
                const score = parseScore(m.score);
                const hasBothPlayers = m.winner1_id && m.loser1_id;
                const isUnconfirmed = m.notes?.includes('unconfirmed');
                const isMissingScore = hasBothPlayers && !score;
                const suggestData = hasBothPlayers ? JSON.stringify({
                  winner: displayName(m.winner1_id),
                  loser: displayName(m.loser1_id),
                  round: m.round,
                  context,
                }) : null;
                return (
                  <>
                  {topGap > 0 && <div style={`height: ${topGap * BASE_H}px; flex-shrink: 0`} />}
                  <div class="match-slot" style={`height: ${slots * BASE_H}px`}>
                    <div class="match">
                      <div class="player winner">
                        <a class="pname" href={playerUrl(m.winner1_id)}>{displayName(m.winner1_id)}</a>
                        {score && <span class="pscore">{score.w}</span>}
                      </div>
                      <div class="player loser">
                        <a class="pname" href={playerUrl(m.loser1_id)}>{displayName(m.loser1_id)}</a>
                        {score && (
                          <span class="pscore">
                            {score.l}{score.tb !== null ? <span class="tb"> ({score.tb})</span> : ''}
                          </span>
                        )}
                      </div>
                      {isUnconfirmed && (
                        <button
                          class="badge badge-btn"
                          onclick={`openSuggestModal(${suggestData})`}
                          title="Resultado no confirmado — haz clic para sugerir"
                        >?</button>
                      )}
                      {isMissingScore && !isUnconfirmed && (
                        <button
                          class="badge badge-btn badge-missing"
                          onclick={`openSuggestModal(${suggestData})`}
                          title="¿Recuerdas este resultado?"
                        >?</button>
                      )}
                    </div>
                  </div>
                  </>
                );
              })}
            </div>
          </div>
          {!isLast && (
            <svg class="connector-col" width={CONN_W} height={bracketH + LABEL_H}>
              {connectors.map(({ upperCY, lowerCY, midY }) => {
                const mx = CONN_W / 2;
                const oy = LABEL_H; // offset so y=0 aligns with top of match area
                return (
                  <>
                    <line x1={-COL_GAP} y1={upperCY + oy} x2={mx}           y2={upperCY + oy} />
                    <line x1={mx}        y1={upperCY + oy} x2={mx}           y2={lowerCY + oy} />
                    <line x1={-COL_GAP} y1={lowerCY + oy} x2={mx}           y2={lowerCY + oy} />
                    <line x1={mx}        y1={midY    + oy} x2={CONN_W + COL_GAP} y2={midY + oy} />
                  </>
                );
              })}
            </svg>
          )}
        </>
      );
    })}
  </div>
</div>

<style>
  .bracket-scroll { overflow-x: auto; padding-bottom: 1rem; }

  .bracket {
    display: flex;
    column-gap: 12px;
    min-width: fit-content;
  }

  .round {
    display: flex;
    flex-direction: column;
    min-width: 172px;
  }

  .round-label {
    height: 28px;
    display: flex;
    align-items: flex-end;
    padding: 0 12px 6px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-text);
    flex-shrink: 0;
  }

  .round-matches {
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .match-slot {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .match {
    flex: 1;
    border: 2px solid var(--c-black);
    overflow: hidden;
    background: #fff;
    box-shadow: var(--shadow-sm);
    position: relative;
  }

  .player {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 7px 10px;
    font-size: 0.87rem;
  }

  .player + .player { border-top: 2px solid var(--c-black); }

  .player.winner { background: var(--c-green); }
  .player.winner .pname { font-weight: 700; color: var(--c-black); }
  .player.loser .pname { color: var(--c-text); font-weight: 300; }
  .pname {
    text-decoration: none;
    padding-bottom: 2px;
    background-image: linear-gradient(currentColor, currentColor);
    background-repeat: no-repeat;
    background-size: 100% 1.5px;
    background-position: left bottom;
    transition: background-size 0.4s ease;
  }
  .pname:hover {
    background-image: linear-gradient(var(--c-yellow), var(--c-yellow));
    background-size: 100% 5px;
  }

  .pscore {
    font-family: "SF Mono", "Fira Code", ui-monospace, monospace;
    font-size: 0.82rem;
    color: var(--c-black);
    margin-left: 8px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .player.loser .pscore { color: var(--c-text); }

  .tb { font-size: 0.7rem; color: var(--c-text); }

  .connector-col {
    flex-shrink: 0;
    overflow: visible;
  }

  .connector-col line {
    stroke: var(--c-black);
    stroke-width: 1.5;
    stroke-linecap: round;
  }

  .badge {
    position: absolute;
    top: 3px;
    right: 5px;
    font-size: 0.6rem;
    font-weight: 700;
    background: var(--c-pink);
    color: var(--c-black);
    border: 1px solid var(--c-black);
    padding: 1px 4px;
  }

  .badge-btn {
    cursor: pointer;
    font-family: inherit;
    transition: box-shadow 0.1s, transform 0.1s;
  }
  .badge-btn:hover {
    box-shadow: 2px 2px 0 var(--c-black);
    transform: translate(-1px, -1px);
  }
  .badge-missing {
    background: var(--c-blue);
  }
</style>
